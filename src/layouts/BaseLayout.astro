---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, canonical, image = '/og-default.png', type = 'website', jsonLd, noindex = false } = Astro.props;
const site = Astro.site ?? new URL(siteConfig.fallbackUrl);
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, site);
const imageUrl = new URL(image, site);
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const naverVerification = import.meta.env.PUBLIC_NAVER_SITE_VERIFICATION;
const gaId = import.meta.env.PUBLIC_GA_ID;
const baseJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteConfig.name,
    alternateName: siteConfig.shortName,
    url: site.href,
    description: siteConfig.description,
    inLanguage: 'ko-KR'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: siteConfig.name,
    description: siteConfig.description,
    url: site.href,
    genre: siteConfig.genre,
    playMode: 'SinglePlayer',
    gamePlatform: ['Web Browser', 'Mobile Web'],
    inLanguage: 'ko-KR',
    isAccessibleForFree: true,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'KRW' }
  }
];
const structured = [...baseJsonLd, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content={siteConfig.themeColor} />
    <meta name="color-scheme" content="light" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={siteConfig.shortName} />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href={new URL('/rss.xml', site)} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    {naverVerification && <meta name="naver-site-verification" content={naverVerification} />}
    {structured.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    {gaId && <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>}
    {gaId && <script is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId, { anonymize_ip: true });
    </script>}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">본문으로 건너뛰기</a>
    <Header currentPath={Astro.url.pathname} />
    <main id="main"><slot /></main>
    <Footer />
    <div class="toast" data-toast role="status" aria-live="polite"></div>
    <script src="/app-shell.js" defer></script>
  </body>
</html>
