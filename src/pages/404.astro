---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
---
<BaseLayout title={`페이지를 찾을 수 없습니다 | ${siteConfig.name}`} description="요청한 페이지가 없거나 주소가 변경되었습니다." noindex={true}>
  <section class="section"><div class="shell content-card" style="text-align:center;max-width:720px">
    <span class="eyebrow">404</span><h1 style="max-width:none">페이지를 찾을 수 없어요</h1>
    <p class="lead" style="margin-inline:auto">주소를 다시 확인하거나 오늘의 게임으로 돌아가세요.</p>
    <a class="button primary" href="/">홈에서 플레이</a>
  </div></section>
</BaseLayout>
