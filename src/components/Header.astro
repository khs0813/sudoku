---
import { siteConfig } from '../config';
const { currentPath = '/' } = Astro.props;
const active = (href: string) => { const base = href.split('#')[0] || '/'; return base === '/' ? currentPath === '/' : currentPath.startsWith(base); };
---
<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label={`${siteConfig.name} 홈`}>
      <span class="brand-mark" aria-hidden="true">{siteConfig.mark}</span>
      <span><strong>{siteConfig.name}</strong><small>{siteConfig.tagline}</small></span>
    </a>
    <nav class="site-nav" aria-label="주요 메뉴">
      <ul class="nav-list">
        {siteConfig.nav.map(([label, href]) => <li><a class:list={['nav-link', { active: active(href) }]} aria-current={active(href) ? 'page' : undefined} href={href}>{label}</a></li>)}
      </ul>
    </nav>
  </div>
</header>
