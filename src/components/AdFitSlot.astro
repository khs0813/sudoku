---
import { adFitConfig } from '../config';
import { createPlacementClientConfig } from '../adfit-config.mjs';

interface Props {
  placement: 'game' | 'guide';
}

const { placement } = Astro.props;
const clientConfig = createPlacementClientConfig(adFitConfig, placement);
const units = clientConfig.units;
const hasDesktop = Boolean(units.desktop.id);
const hasMobile = Boolean(units.mobile.id);
const shouldRender = adFitConfig.enabled && (hasDesktop || hasMobile);
const configJson = JSON.stringify(clientConfig)
  .replace(/</g, '\\u003c')
  .replace(/>/g, '\\u003e')
  .replace(/&/g, '\\u0026');
const styleVars = [
  `--adfit-desktop-width:${units.desktop.width}px`,
  `--adfit-desktop-height:${units.desktop.height}px`,
  `--adfit-mobile-width:${units.mobile.width}px`,
  `--adfit-mobile-height:${units.mobile.height}px`
].join(';');
---
{shouldRender && (
  <>
    <div
      class:list={[
        'adfit-slot',
        `adfit-slot--${placement}`,
        { 'adfit-slot--has-desktop': hasDesktop, 'adfit-slot--has-mobile': hasMobile }
      ]}
      data-adfit-placement={placement}
      aria-label="광고"
      style={styleVars}
    >
      <span class="adfit-label">광고</span>
    </div>
    <script is:inline type="application/json" id="adfit-config" set:html={configJson}></script>
    <script src="/js/adfit-loader.js" defer></script>
  </>
)}
